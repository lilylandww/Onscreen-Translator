<Window x:Class="WpfAppTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:WpfAppTest"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="J2E OCR Translator" 
    Height="450" Width="800"
    Topmost="False"
    ResizeMode="NoResize"
    Background="Transparent"
    AllowsTransparency="True"
    WindowStyle="None"
    Closing="Window_Closing"
    Deactivated="Window_Deactivated"
    Activated="Window_Activated"
    Loaded="Window_Loaded"
    Unloaded="Window_Unloaded"
    mc:Ignorable="d"
    >
    <Window.Resources>
        <Style x:Key="SymbolTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>
    <Grid d:Background="NavajoWhite">
        <Viewbox>
            <Image x:Name="BG" Stretch="UniformToFill" />
        </Viewbox>
        <Canvas 
            Name="vancas" 
            MouseEnter="Canvas_MouseEnter"
            MouseLeave="Canvas_MouseLeave"
            MouseDown="Canvas_MouseDown"
            MouseMove="Canvas_MouseMove"
            MouseUp="Canvas_MouseUp"
            Cursor="Cross">
            <Canvas.Clip>
                <CombinedGeometry GeometryCombineMode="Exclude">
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry x:Name="FullWindow" />
                    </CombinedGeometry.Geometry1>
                    <CombinedGeometry.Geometry2>
                        <RectangleGeometry x:Name="clippingGeometry" />
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Canvas.Clip>
            <Canvas.Background>
                <SolidColorBrush
                    x:Name="BackgroundBrush"
                    Opacity="0"
                />
            </Canvas.Background>
            <Canvas.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Name="TestButton"
                        Header="Test"
                        />
                </ContextMenu>
            </Canvas.ContextMenu>
            <TextBox
                Name="translatedTextBlock"
                TextWrapping="Wrap"
                TextAlignment="Center"
                VerticalAlignment="Center"
                Cursor="Arrow"
                FontSize="16"
                Foreground="DarkSlateGray"
                IsReadOnly="True"
                IsReadOnlyCaretVisible="False"
                BorderThickness="0"
                SelectionBrush="DodgerBlue"
                SelectionOpacity="0.5"
                VerticalScrollBarVisibility="Disabled">
                <TextBox.Background>
                    <SolidColorBrush Color="AntiqueWhite" Opacity="0.8"/>
                </TextBox.Background>
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy" Command="ApplicationCommands.Copy" />
                        <MenuItem Header="Select All" Command="ApplicationCommands.SelectAll" />
                        <Separator />
                        <MenuItem Header="Edit" Click="EditMenuItem_Click" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
            <Button
                x:Name="FinishEditButton"
                Visibility="Collapsed"
                Click="FinishEditButton_Click"
                Padding="5"
                Cursor="Hand"
                ToolTip="Finish Editing">
                <wpfui:SymbolIcon Symbol="CheckboxChecked24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" />
                <Button.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Direction="-90"
                        Opacity="0.8"/>
                </Button.Effect>
            </Button>
            
        </Canvas>
        <Border
            x:Name="TopButtonStack"
            Margin="12"
            Padding="8"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            d:Background="Gray"
            d:Visibility="Visible"
            CornerRadius="8"
            MouseEnter="Canvas_MouseEnter"
            MouseLeave="Canvas_MouseLeave"
            Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="32"
                    Direction="-90"
                    Opacity="0.8"
                />
            </Border.Effect>

            <StackPanel
                Margin="4,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                >
                <Button
                    x:Name="CancelButton"
                    Width="32"
                    Height="32"
                    Margin="0"
                    Click="CancelItemClick"
                    ToolTip="Cancel (Esc)">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>
                <Button
                    x:Name="SettingsButton"
                    Width="32"
                    Height="32"
                    Margin="4,0,0,0"
                    Click="SettingsButton_Click"
                    ToolTip="Settings">
                    <wpfui:SymbolIcon Symbol="Settings24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </Button>
                <Separator Width="1" Background="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,4" />
                <TextBlock Text="OCR:" VerticalAlignment="Center" FontSize="12" Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}" Margin="4,0" />
                <ComboBox
                    x:Name="OcrModelComboBox"
                    Width="130"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    ToolTip="OCR Model"
                    SelectionChanged="OcrModelComboBox_SelectionChanged" />
                <Button
                    x:Name="RefreshOcrModelsButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Click="RefreshOcrModelsButton_Click"
                    ToolTip="Refresh OCR Models"
                    Margin="4,0,0,0">
                    <wpfui:SymbolIcon Symbol="ArrowSync24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </Button>
                <Separator Width="1" Background="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,4" />
                <TextBlock Text="Trans:" VerticalAlignment="Center" FontSize="12" Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}" Margin="4,0" />
                <ComboBox
                    x:Name="TranslationProviderComboBox"
                    Width="100"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    ToolTip="Translation Provider"
                    SelectionChanged="TranslationProviderComboBox_SelectionChanged" />
                <ComboBox
                    x:Name="TranslationModelComboBox"
                    Width="120"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    ToolTip="Translation Model"
                    Visibility="Collapsed"
                    SelectionChanged="TranslationModelComboBox_SelectionChanged" />
                <Button
                    x:Name="RefreshTranslationModelsButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Click="RefreshTranslationModelsButton_Click"
                    ToolTip="Refresh Translation Models"
                    Visibility="Collapsed"
                    Margin="4,0,0,0">
                    <wpfui:SymbolIcon Symbol="ArrowSync24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </Button>
                <Separator Width="1" Background="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,4" />
                <ToggleButton
                    x:Name="SearchToggleButton"
                    Checked="SearchToggleButton_Checked"
                    Unchecked="SearchToggleButton_Unchecked"
                    ToolTip="Toggle Dictionary Search">
                    <wpfui:SymbolIcon Symbol="Search24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </ToggleButton>
                <ToggleButton
                    x:Name="FuriganaToggleButton"
                    ToolTip="Furigana (Phase 3)">
                    <wpfui:SymbolIcon Symbol="ReadingList24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </ToggleButton>
                <ToggleButton
                    x:Name="CaptureModeToggleButton"
                    Checked="CaptureModeToggleButton_Checked"
                    Unchecked="CaptureModeToggleButton_Unchecked"
                    IsChecked="True"
                    ToolTip="Capture Mode Enabled (Click to disable)">
                    <wpfui:SymbolIcon Symbol="Cursor24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                </ToggleButton>
                <Button
                    x:Name="ScreenSwitchButton"
                    Click="ScreenSwitchButton_Click"
                    ToolTip="Switch Screen (Monitor 1)">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:SymbolIcon Symbol="Desktop24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                        <TextBlock x:Name="ScreenNumberText" Text="1" FontSize="11"
                                   Margin="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Border
            x:Name="SearchPanel"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="15"
            MaxWidth="550"
            Padding="12"
            CornerRadius="12"
            Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#2C2C2C" Opacity="0.95"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="24"
                    Direction="-90"
                    Opacity="0.4"
                    ShadowDepth="4"/>
            </Border.Effect>
            
            <StackPanel Orientation="Vertical">
                <!-- Search Input Section -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Grid Width="200" Height="36" Margin="0,0,8,0">
                        <Border
                            Background="{wpfui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid Margin="8,0">
                                <TextBlock
                                    x:Name="SearchPlaceholder"
                                    Text="Search dictionary..."
                                    Foreground="{wpfui:ThemeResource TextFillColorTertiaryBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,28,0"
                                    IsHitTestVisible="False"/>
                                <TextBox
                                    x:Name="SearchTermTextBox"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    VerticalContentAlignment="Center"
                                    Padding="0"
                                    KeyDown="SearchTermTextBox_KeyDown"
                                    TextChanged="SearchTermTextBox_TextChanged"
                                    Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <Button
                                    x:Name="ClearSearchButton"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,4,0"
                                    Click="ClearSearchButton_Click"
                                    Visibility="Collapsed"
                                    Cursor="Hand">
                                    <wpfui:SymbolIcon Symbol="Dismiss20" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                    <Button
                        x:Name="SearchExecuteButton"
                        Width="100"
                        Height="36"
                        Click="SearchExecuteButton_Click"
                        Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <wpfui:SymbolIcon Symbol="Search24" Margin="0,0,6,0" FontSize="20"/>
                            <TextBlock Text="Search" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Results Count Indicator -->
                <TextBlock
                    x:Name="ResultsCountText"
                    Text=""
                    FontSize="11"
                    Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,0,0,8"
                    Visibility="Collapsed"/>

                <!-- Search Results List -->
                <Border
                    CornerRadius="8"
                    Background="{wpfui:ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    MaxHeight="300">
                    <ScrollViewer 
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SearchResultsListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="Transparent"
                                        Padding="12,10"
                                        BorderBrush="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{wpfui:ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- Word and Reading -->
                                            <TextBlock Margin="0,0,0,6">
                                                <Run Text="{Binding Word}" FontWeight="SemiBold" FontSize="15" Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"/>
                                                <Run Text="  [" Foreground="{wpfui:ThemeResource TextFillColorTertiaryBrush}"/>
                                                <Run Text="{Binding Reading}" Foreground="{wpfui:ThemeResource TextFillColorTertiaryBrush}" FontSize="13"/>
                                                <Run Text="]" Foreground="{wpfui:ThemeResource TextFillColorTertiaryBrush}"/>
                                            </TextBlock>
                                            
                                            <!-- Meanings -->
                                            <ItemsControl ItemsSource="{Binding Meanings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock 
                                                            Text="{Binding}" 
                                                            TextWrapping="Wrap"
                                                            FontSize="13"
                                                            Foreground="{wpfui:ThemeResource TextFillColorPrimaryBrush}"
                                                            Margin="0,3"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        
    </Grid>

    
</Window>
