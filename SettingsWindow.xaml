<Window x:Class="WpfAppTest.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings — J2E OCR Translator"
    Width="580"
    Height="620"
    MinWidth="480"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    mc:Ignorable="d"
    Background="{wpfui:ThemeResource ApplicationBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{wpfui:ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SubSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{wpfui:ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{wpfui:ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SettingsPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ProviderCard" TargetType="Border">
            <Setter Property="Background" Value="{wpfui:ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{wpfui:ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable Settings Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,20,24,8">
            <StackPanel>

                <!-- ═══════ OCR Settings ═══════ -->
                <TextBlock Text="OCR Settings" Style="{StaticResource SectionHeader}"/>

                <Border Style="{StaticResource ProviderCard}">
                    <StackPanel>
                        <!-- OCR Provider Selection -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Provider:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="OcrProviderComboBox"
                                Style="{StaticResource SettingsComboBox}"
                                SelectionChanged="OcrProviderComboBox_SelectionChanged"/>
                        </Grid>

                        <!-- Dynamic OCR Provider Settings -->
                        <StackPanel x:Name="OcrProviderSettingsPanel">
                            <!-- Ollama Settings -->
                            <StackPanel x:Name="OcrOllamaPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="OcrOllamaBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="http://localhost:11434"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="OcrOllamaModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshOcrOllamaModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshOcrModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- OpenAI Settings -->
                            <StackPanel x:Name="OcrOpenAIPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="OcrOpenAIBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="https://api.openai.com/v1"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="OcrOpenAIApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="OcrOpenAIModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshOcrOpenAIModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshOcrModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- OpenAI-Compatible Settings -->
                            <StackPanel x:Name="OcrOpenAICompatiblePanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="OcrCompatBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="http://localhost:8080/v1"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="OcrCompatApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="OcrCompatModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshOcrCompatModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshOcrModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Test Connection -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="TestOcrConnectionButton"
                                Style="{StaticResource SmallButton}"
                                Click="TestOcrConnection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="PlugConnected24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Test Connection"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="OcrConnectionStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                                FontSize="11" Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════ Translation Settings ═══════ -->
                <TextBlock Text="Translation Settings" Style="{StaticResource SectionHeader}" Margin="0,8,0,12"/>

                <Border Style="{StaticResource ProviderCard}">
                    <StackPanel>
                        <!-- Translation Provider Selection -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Provider:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="TranslationProviderComboBox"
                                Style="{StaticResource SettingsComboBox}"
                                SelectionChanged="TranslationProviderComboBox_SelectionChanged"/>
                        </Grid>

                        <!-- Dynamic Translation Provider Settings -->
                        <StackPanel x:Name="TranslationProviderSettingsPanel">
                            <!-- Google Settings -->
                            <StackPanel x:Name="TransGooglePanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="TransGoogleApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                            </StackPanel>

                            <!-- DeepL Settings -->
                            <StackPanel x:Name="TransDeepLPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="TransDeepLApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Ollama Settings -->
                            <StackPanel x:Name="TransOllamaPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="TransOllamaBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="http://localhost:11434"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="TransOllamaModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshTransOllamaModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshTranslationModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- OpenAI Settings -->
                            <StackPanel x:Name="TransOpenAIPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="TransOpenAIBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="https://api.openai.com/v1"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="TransOpenAIApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="TransOpenAIModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshTransOpenAIModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshTranslationModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- OpenAI-Compatible Settings -->
                            <StackPanel x:Name="TransOpenAICompatiblePanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL:" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="TransCompatBaseUrlTextBox"
                                        Style="{StaticResource SettingsTextBox}"
                                        Text="http://localhost:8080/v1"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key:" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Column="1" x:Name="TransCompatApiKeyBox"
                                        Style="{StaticResource SettingsPasswordBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Model:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="TransCompatModelComboBox"
                                        Style="{StaticResource SettingsComboBox}"
                                        IsEditable="True"/>
                                    <Button Grid.Column="2" x:Name="RefreshTransCompatModelsButton"
                                        Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                        Click="RefreshTranslationModels_Click" ToolTip="Refresh models">
                                        <wpfui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Test Connection -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="TestTranslationConnectionButton"
                                Style="{StaticResource SmallButton}"
                                Click="TestTranslationConnection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="PlugConnected24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Test Connection"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="TranslationConnectionStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                                FontSize="11" Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════ Furigana Settings ═══════ -->
                <TextBlock Text="Furigana Settings" Style="{StaticResource SectionHeader}" Margin="0,8,0,12"/>

                <Border Style="{StaticResource ProviderCard}">
                    <StackPanel>
                        <!-- Enable Furigana -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="FuriganaEnabledCheckBox"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Enable furigana overlay"
                                Style="{StaticResource FieldLabel}" FontSize="12"/>
                        </Grid>

                        <!-- Sidecar URL -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sidecar URL:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" x:Name="FuriganaSidecarUrlTextBox"
                                Style="{StaticResource SettingsTextBox}"
                                Text="http://127.0.0.1:8765"/>
                        </Grid>

                        <!-- Auto-start sidecar -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="FuriganaAutoStartCheckBox"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Auto-start sidecar on launch"
                                Style="{StaticResource FieldLabel}" FontSize="12"/>
                        </Grid>

                        <!-- Use FLFL fallback -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="FuriganaUseFlflCheckBox"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Use FLFL model for OOV fallback"
                                Style="{StaticResource FieldLabel}" FontSize="12"/>
                        </Grid>

                        <!-- Test Connection -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="FuriganaTestConnectionButton"
                                Style="{StaticResource SmallButton}"
                                Click="FuriganaTestConnection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="PlugConnected24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Test Connection"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="FuriganaConnectionStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                                FontSize="11" Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Separator Margin="0,10,0,10"
                            BorderBrush="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}"/>

                        <!-- Sidecar Controls -->
                        <TextBlock Text="Sidecar Controls" Style="{StaticResource SubSectionHeader}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="FuriganaInstallButton"
                                Style="{StaticResource SmallButton}" Margin="0,0,6,0"
                                Click="FuriganaInstall_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Install Sidecar"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="FuriganaStartButton"
                                Style="{StaticResource SmallButton}" Margin="0,0,6,0"
                                Click="FuriganaStart_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="Play24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Start"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="FuriganaStopButton"
                                Style="{StaticResource SmallButton}"
                                Click="FuriganaStop_Click">
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="Stop24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Stop"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Status -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" x:Name="FuriganaStatusText"
                                Text="Not running"
                                FontSize="12" VerticalAlignment="Center"
                                Foreground="{wpfui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="1" Background="{wpfui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{wpfui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                    Foreground="{wpfui:ThemeResource TextFillColorTertiaryBrush}"
                    Text="Changes are applied immediately"/>
                <Button Grid.Column="1" x:Name="CancelButton" Content="Cancel"
                    Click="CancelButton_Click" Padding="24,6" Margin="0,0,8,0"/>
                <Button Grid.Column="2" x:Name="SaveButton" Content="Save"
                    Click="SaveButton_Click" Padding="24,6"
                    FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
